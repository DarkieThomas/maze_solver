from gpiozero import Button
from signal import pause

STATE_FILE = "/tmp/robot_state"

button = Button(
    17,
    pull_up=True,
    bounce_time=0.2
)

def toggle():
    try:
        with open(STATE_FILE, "r") as f:
            state = f.read().strip()
    except:
        state = "0"

    state = "1" if state == "0" else "0"

    with open(STATE_FILE, "w") as f:
        f.write(state)

    print("STATE =", state)

button.when_pressed = toggle

print("Button ready")
pause()

